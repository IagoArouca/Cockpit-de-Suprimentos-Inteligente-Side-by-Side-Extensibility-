  "description": "Projeto Senior de Gestao de Fornecedores - BTP CAP",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@sap/cds": "^8.9.0",
    "@sap/xssec": "^4.0.0",
    "@sap/xsenv": "^5.0.0",
    "express": "^4.21.2",
    "sqlite3": "^5.1.7",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8.9.0"
