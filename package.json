{
  "name": "cockpit-suprimentos",
  "version": "1.0.0",
  "description": "Projeto Senior de Gestao de Fornecedores - BTP CAP",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@sap/cds": "^8.9.0",
    "@sap/xssec": "^4.0.0",
    "@sap/xsenv": "^5.0.0",
    "express": "^4.21.2",
    "sqlite3": "^5.1.7",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8.9.0",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build",
    "watch-avaliacoes": "cds watch --open com.senior.suprimentos.avaliacoes/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite"
      },
      "API_BUSINESS_PARTNER": {
        "kind": "odata-v2",
        "model": "srv/external/API_BUSINESS_PARTNER"
      }
    },
    "features": {
      "fetch_csrf": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/avaliacoes"
  ]
}
